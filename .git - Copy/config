[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	symlinks = false
	ignorecase = true
[remote "origin"]
	url = https://github.com/damzempire/CurrentDao-backend.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "main"]
	remote = origin
	merge = refs/heads/main
	vscode-merge-base = origin/main
[branch "feature/high-volume-transaction-processing"]
	vscode-merge-base = origin/main
	remote = origin
	merge = refs/heads/feature/high-volume-transaction-processing
[lfs]
	repositoryformatversion = 0
[remote "upstream"]
	url = https://github.com/CurrentDao-org/CurrentDao-backend.git
	fetch = +refs/heads/*:refs/remotes/upstream/*
[branch "Transaction-Processing-"]
	vscode-merge-base = origin/main
	remote = origin
